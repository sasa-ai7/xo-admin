# =============================================================================
# REQUIRED for Vite admin (local dev + production build)
# Copy to ".env.local" in this folder and fill every required value.
# Vite loads .env.local automatically (see vite.config.ts envDir).
# =============================================================================

# --- Firebase web client (import.meta.env.VITE_*) ---
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=xo-arenaneon-clash.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=xo-arenaneon-clash
VITE_FIREBASE_STORAGE_BUCKET=xo-arenaneon-clash.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=928308967161
VITE_FIREBASE_APP_ID=1:928308967161:web:11f5134abf24ae35311428

# --- Admin Firebase Auth (used after PIN) ---
VITE_ADMIN_EMAIL=adminarena77@gmail.com
VITE_ADMIN_PASSWORD=

# =============================================================================
# Optional (recommended)
# =============================================================================
VITE_FIREBASE_MEASUREMENT_ID=G-QJRY9GS06T
VITE_ADMIN_PIN_HASH=
# If false (recommended for prod), Firebase admin sign-in MUST succeed.
# If true, a correct PIN alone grants access (dev only).
VITE_ALLOW_LOCAL_PIN_FALLBACK=false
# After deploying Cloud Functions adminDeleteUserWithCleanup, set to true:
VITE_ENABLE_ADMIN_DELETE_USER=false

# =============================================================================
# Server / Cloud Functions (not used by Vite client)
# =============================================================================
ADMIN_EMAIL=adminarena77@gmail.com
FIREBASE_ADMIN_PROJECT_ID=xo-arenaneon-clash
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY=
